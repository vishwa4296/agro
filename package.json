{
  "name": "project",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run start -w backend",
    "dev": "concurrently -n \"frontend,backend\" -c \"blue,green\" \"npm run dev -w frontend\" \"npm run start -w backend\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
